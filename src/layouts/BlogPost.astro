---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import SeriesNavigation from '../components/SeriesNavigation.astro';
import SeriesNavigationHeader from '../components/SeriesNavigationHeader.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const { title, summary, date, heroImage, entry } = Astro.props;

// Build breadcrumb items based on series presence
const breadcrumbItems = [];
if (entry?.data?.seriesTitle) {
  // Ideally, link to the series overview if possible, or just text
  breadcrumbItems.push({ label: entry.data.seriesTitle, href: undefined });
}
breadcrumbItems.push({ label: title, href: undefined });
---

<Layout title={title} description={summary}>
	<article class="max-w-3xl mx-auto pt-8">
    
    <div class="mb-6 relative z-10">
      <Breadcrumb items={breadcrumbItems} className="text-gray-400" />
    </div>
    
    {/* Left-Aligned Hero Section */}
    <div class="mb-12 border-b border-white/10 pb-12">
        {entry?.data?.series && (
            <div class="mb-6">
                <SeriesNavigationHeader currentPost={entry} />
            </div>
        )}

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">{title}</h1>
        
        {entry?.data?.subtitle && (
            <p class="text-xl text-steel-grey mb-8 leading-relaxed max-w-2xl">
                {entry.data.subtitle}
            </p>
        )}
        
        <div class="flex flex-wrap items-center gap-6 text-sm font-mono text-silver">
             <div class="flex items-center gap-2">
                <span class="text-steel-blue">Orchestrated by</span>
                <span class="text-white font-bold">Tim Varley</span>
                {entry?.data?.inference && (
                    <>
                        <span class="text-steel-blue">with</span>
                        <span class="text-white font-bold">{entry.data.inference}</span>
                    </>
                )}
            </div>
            
            <div class="w-1 h-1 bg-white/20 rounded-full"></div>
            
            <div class="flex items-center gap-2">
                <span class="text-steel-blue">Published</span>
                <FormattedDate date={date} />
            </div>
            
             {entry?.data?.category && (
                <>
                    <div class="w-1 h-1 bg-white/20 rounded-full"></div>
                    <span class="uppercase tracking-wider text-xs px-2 py-0.5 bg-white/5 rounded border border-white/5">
                        {entry.data.category}
                    </span>
                </>
            )}
        </div>

        {heroImage && (
            <div class="mt-10 rounded-2xl overflow-hidden shadow-2xl border border-white/10">
                <img src={heroImage} alt="" class="w-full h-auto max-h-[400px] object-cover" />
            </div>
        )}
    </div>
    
	<div class="prose prose-invert prose-lg max-w-none">
		<div class="markdown-content max-w-none">
			<slot />
		</div>
	</div>

	<SeriesNavigation currentPost={entry} />
	</article>
</Layout>

<style is:global>
    /* 
       Global styles for the markdown content to match the Euler aesthetic.
       We target the specific container to avoid leaking styles too broadly.
    */
    /* Hide the first H1 in content since we show it in Hero */
    .markdown-content > h1:first-child {
        display: none;
    }
    
    .markdown-content h1 {
        font-family: var(--font-serif);
        font-size: 2.5rem;
        font-weight: 700;
        color: white;
        margin-top: 2rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .markdown-content h2 {
        font-family: var(--font-serif);
        font-size: 1.8rem;
        font-weight: 700;
        color: white;
        margin-top: 3rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .markdown-content h3 {
        font-family: var(--font-sans);
        font-size: 1.4rem;
        font-weight: 600;
        color: #e2e8f0; /* slalt-200 */
        margin-top: 2rem;
        margin-bottom: 1rem;
    }

    .markdown-content p {
        color: #94a3b8; /* slate-400 */
        line-height: 1.8;
        margin-bottom: 1.5rem;
    }

    .markdown-content ul {
        list-style-type: none;
        padding-left: 0;
        margin-bottom: 2rem;
    }

    .markdown-content li {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 0.75rem;
        color: #cbd5e1; /* slate-300 */
    }

    .markdown-content li::before {
        content: "•";
        position: absolute;
        left: 0;
        color: #64ffda; /* accent color */
        font-weight: bold;
    }

    .markdown-content strong {
        color: white;
        font-weight: 600;
    }
    
    .markdown-content code {
        font-family: var(--font-mono);
        color: #64ffda;
        background: rgba(255, 255, 255, 0.05);
        padding: 0.2em 0.4em;
        border-radius: 4px;
        font-size: 0.85em;
    }
</style>
