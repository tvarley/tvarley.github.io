---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import SeriesNavigation from '../components/SeriesNavigation.astro';
import SeriesNavigationHeader from '../components/SeriesNavigationHeader.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const { title, summary, date, heroImage, entry } = Astro.props;

// Get all writings for related articles
const allWritings = await getCollection('writings');

// Build breadcrumb items based on series presence
const breadcrumbItems = [];
if (entry?.data?.seriesTitle) {
  // Ideally, link to the series overview if possible, or just text
  breadcrumbItems.push({ label: entry.data.seriesTitle, href: undefined });
}
breadcrumbItems.push({ label: title, href: undefined });
---

<Layout title={title} description={summary} client:load={true}>
	<div class="max-w-7xl mx-auto pt-8 px-6">
		<div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
			{/* Main Content */}
			<article class="lg:col-span-3">
    
    <div class="mb-6 relative z-10">
      <Breadcrumb items={breadcrumbItems} className="text-gray-400" />
    </div>
    
    {/* Left-Aligned Hero Section */}
    <div class="mb-12 border-b border-white/10 pb-12">
        {entry?.data?.series && (
            <div class="mb-6">
                <SeriesNavigationHeader currentPost={entry} />
            </div>
        )}

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">{title}</h1>
        
        {entry?.data?.subtitle && (
            <p class="text-xl text-steel-grey mb-8 leading-relaxed max-w-2xl">
                {entry.data.subtitle}
            </p>
        )}
        
        <div class="flex flex-wrap items-center gap-6 text-sm font-mono text-silver">
             <div class="flex items-center gap-2">
                <span class="text-steel-blue">Orchestrated by</span>
                <span class="text-white font-bold">Tim Varley</span>
                {entry?.data?.inference && (
                    <>
                        <span class="text-steel-blue">with</span>
                        <span class="text-white font-bold">{entry.data.inference}</span>
                    </>
                )}
            </div>
            
            <div class="w-1 h-1 bg-white/20 rounded-full"></div>
            
            <div class="flex items-center gap-2">
                <span class="text-steel-blue">Published</span>
                <FormattedDate date={date} />
            </div>
            
             {entry?.data?.category && (
                <>
                    <div class="w-1 h-1 bg-white/20 rounded-full"></div>
                    <span class="uppercase tracking-wider text-xs px-2 py-0.5 bg-white/5 rounded border border-white/5">
                        {entry.data.category}
                    </span>
                </>
            )}
        </div>

        {heroImage && (
            <div class="mt-10 rounded-2xl overflow-hidden shadow-2xl border border-white/10">
                <img src={heroImage} alt="" class="w-full h-auto max-h-[400px] object-cover" />
            </div>
        )}
    </div>
    
	<div class="prose prose-invert prose-lg max-w-none">
		<div class="markdown-content max-w-none">
			<slot />
		</div>
	</div>

	<SeriesNavigation currentPost={entry} />
			</article>

			{/* Active Reader Sidebar */}
			<aside class="lg:col-span-1">
				<div class="sticky top-24 space-y-8">
					{/* Reading Progress */}
					<div class="sidebar-section bg-charcoal-light border border-white/10 rounded-2xl p-6">
						<h3 class="text-sm font-mono uppercase tracking-widest text-steel-blue mb-4">Reading Progress</h3>
						<div class="w-full bg-white/5 rounded-full h-2 mb-2">
							<div id="reading-progress" class="bg-steel-blue h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
						</div>
						<div class="text-xs text-silver font-mono">
							<span id="progress-text">0%</span> complete
						</div>
					</div>

					{/* Article Sections */}
					<div class="sidebar-section bg-charcoal-light border border-white/10 rounded-2xl p-6">
						<h3 class="text-sm font-mono uppercase tracking-widest text-steel-blue mb-4">Article Sections</h3>
						<nav id="toc-nav" class="space-y-2">
							<div class="sidebar-loading text-xs text-silver">Loading sections...</div>
						</nav>
					</div>

					{/* Related Articles */}
					<div class="sidebar-section bg-charcoal-light border border-white/10 rounded-2xl p-6">
						<h3 class="text-sm font-mono uppercase tracking-widest text-steel-blue mb-4">Related Articles</h3>
						<div id="related-articles" class="space-y-3">
							<div class="sidebar-loading text-xs text-silver">Finding related articles...</div>
						</div>
					</div>
				</div>
			</aside>
		</div>
	</div>

	<script define:vars={{ allWritings, currentEntry: entry }}>
		// Active Reader Sidebar functionality
		
		// Reading Progress
		function updateReadingProgress() {
			const article = document.querySelector('article');
			const progressBar = document.getElementById('reading-progress');
			const progressText = document.getElementById('progress-text');
			
			if (!article || !progressBar || !progressText) return;
			
			const articleRect = article.getBoundingClientRect();
			const windowHeight = window.innerHeight;
			
			// Calculate how much of the article is visible
			const articleTop = articleRect.top;
			const articleHeight = articleRect.height;
			const scrollY = window.scrollY;
			
			// Progress is based on how far we've scrolled past the article start
			const startReadPoint = articleTop + scrollY - windowHeight * 0.8;
			const endReadPoint = startReadPoint + articleHeight - windowHeight * 0.2;
			
			let progress = Math.max(0, Math.min(1, (scrollY - startReadPoint) / (endReadPoint - startReadPoint)));
			progress = Math.min(1, Math.max(0, progress));
			
			progressBar.style.width = `${progress * 100}%`;
			progressText.textContent = `${Math.round(progress * 100)}`;
		}

		// Article Sections (TOC)
		function buildTableOfContents() {
			const tocNav = document.getElementById('toc-nav');
			if (!tocNav) return;
			
			// Try different selectors for headings
			let headings = document.querySelectorAll('.markdown-content h2');
			if (headings.length === 0) {
				headings = document.querySelectorAll('article h2'); // Fallback
			}
			if (headings.length === 0) {
				headings = document.querySelectorAll('h2'); // Last resort
			}
			
			// Clear loading text
			tocNav.innerHTML = '';
			
			if (headings.length === 0) {
				tocNav.innerHTML = '<p class="text-xs text-silver">No sections found</p>';
				return;
			}
			
			headings.forEach((heading, index) => {
				const id = `heading-${index}`;
				heading.id = id;
				
				const link = document.createElement('a');
				link.href = `#${id}`;
				link.textContent = heading.textContent;
				link.className = 'block text-sm text-silver hover:text-steel-blue transition-colors py-1 border-l-2 border-transparent hover:border-steel-blue pl-3';
				
				tocNav.appendChild(link);
			});
		}

		// Related Articles
		function buildRelatedArticles() {
			const relatedContainer = document.getElementById('related-articles');
			if (!relatedContainer) return;
			
			// Clear loading text
			relatedContainer.innerHTML = '';
			
			// Find related articles based on tags, series, or category
			const related = allWritings
				.filter(writing => {
					if (writing.id === currentEntry.id) return false; // Exclude current article
					
					// Same series
					if (writing.data.series && currentEntry.data.series && writing.data.series === currentEntry.data.series) {
						return true;
					}
					
					// Same tags
					if (writing.data.tags && currentEntry.data.tags) {
						return writing.data.tags.some(tag => currentEntry.data.tags.includes(tag));
					}
					
					// Same category
					if (writing.data.category && currentEntry.data.category) {
						return writing.data.category === currentEntry.data.category;
					}
					
					return false;
				})
				.slice(0, 3); // Limit to 3 related articles
			
			if (related.length === 0) {
				relatedContainer.innerHTML = '<p class="text-xs text-silver">No related articles found</p>';
				return;
			}
			
			related.forEach(writing => {
				const articleDiv = document.createElement('div');
				articleDiv.innerHTML = `
					<a href="/writings/${writing.id}/" class="block group">
						<h4 class="text-sm text-white group-hover:text-steel-blue transition-colors line-clamp-2 mb-1">
							${writing.data.title}
						</h4>
						<p class="text-xs text-silver line-clamp-1">
							${writing.data.summary || 'No summary available'}
						</p>
					</a>
				`;
				relatedContainer.appendChild(articleDiv);
			});
		}

		// Enhanced Code Blocks
		function enhanceCodeBlocks() {
			const codeBlocks = document.querySelectorAll('.markdown-content pre');
			
			codeBlocks.forEach((pre) => {
				// Skip if already enhanced
				if (pre.querySelector('.code-copy-btn')) return;
				
				// Create wrapper
				const wrapper = document.createElement('div');
				wrapper.className = 'relative group';
				pre.parentNode.insertBefore(wrapper, pre);
				wrapper.appendChild(pre);
				
				// Add copy button
				const copyBtn = document.createElement('button');
				copyBtn.className = 'code-copy-btn absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-charcoal border border-white/10 rounded px-2 py-1 text-xs font-mono text-silver hover:text-white hover:border-steel-blue';
				copyBtn.innerHTML = `
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
					</svg>
				`;
				
				copyBtn.addEventListener('click', async () => {
					const code = pre.querySelector('code')?.textContent || pre.textContent;
					try {
						await navigator.clipboard.writeText(code);
						copyBtn.innerHTML = `
							<svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
							</svg>
						`;
						setTimeout(() => {
							copyBtn.innerHTML = `
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
								</svg>
							`;
						}, 2000);
					} catch (err) {
						console.error('Failed to copy code:', err);
					}
				});
				
				wrapper.appendChild(copyBtn);
				
				// Add language label if available
				const code = pre.querySelector('code');
				if (code && code.className) {
					const langMatch = code.className.match(/language-(\w+)/);
					if (langMatch) {
						const langLabel = document.createElement('div');
						langLabel.className = 'absolute top-3 left-3 opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-charcoal border border-white/10 rounded px-2 py-1 text-xs font-mono text-steel-blue';
						langLabel.textContent = langMatch[1].toUpperCase();
						wrapper.appendChild(langLabel);
					}
				}
			});
		}

		// Sidebar collapse functionality
		function initSidebarToggle() {
			// Sidebar is now always visible - no toggle functionality
		}

		// Function to initialize sidebar when content is ready
		function initializeSidebar() {
			const tocNav = document.getElementById('toc-nav');
			const relatedContainer = document.getElementById('related-articles');
			const headings = document.querySelectorAll('.markdown-content h2, article h2, h2');
			
			// Check if we have the containers and some content to work with
			if (tocNav && relatedContainer && headings.length > 0) {
				buildTableOfContents();
				buildRelatedArticles();
				enhanceCodeBlocks();
				initSidebarToggle();
				updateReadingProgress();
				return true; // Successfully initialized
			}
			return false; // Not ready yet
		}

		// Watch for content changes using MutationObserver
		function watchForContent() {
			const markdownContent = document.querySelector('.markdown-content');
			if (!markdownContent) return;
			
			const observer = new MutationObserver((mutations) => {
				// Check if we now have headings
				const headings = document.querySelectorAll('.markdown-content h2, article h2, h2');
				if (headings.length > 0) {
					buildTableOfContents();
					observer.disconnect(); // Stop watching once we have content
				}
			});
			
			observer.observe(markdownContent, {
				childList: true,
				subtree: true
			});
		}

		// Try to initialize immediately
		if (!initializeSidebar()) {
			// Start watching for content changes
			watchForContent();
			
			// Also try with delays as fallback
			setTimeout(() => {
				if (!initializeSidebar()) {
					setTimeout(() => {
						if (!initializeSidebar()) {
							setTimeout(() => {
								initializeSidebar(); // Final attempt
							}, 1000);
						}
					}, 500);
				}
			}, 100);
		}

		// Update progress on scroll
		window.addEventListener('scroll', updateReadingProgress);
		
		// Smooth scroll for ToC links with offset for navbar
		document.addEventListener('click', (e) => {
			if (e.target.closest('#toc-nav a')) {
				e.preventDefault();
				const link = e.target.closest('#toc-nav a');
				const target = document.querySelector(link.getAttribute('href'));
				if (target) {
					const offset = 100; // Offset for navbar
					const elementPosition = target.getBoundingClientRect().top;
					const offsetPosition = elementPosition + window.pageYOffset - offset;
					
					window.scrollTo({
						top: offsetPosition,
						behavior: 'smooth'
					});
				}
			}
		});
	</script>
</Layout>

<style is:global>
    /* 
       Global styles for the markdown content to match the Euler aesthetic.
       We target the specific container to avoid leaking styles too broadly.
    */
    /* Hide the first H1 in content since we show it in Hero */
    .markdown-content > h1:first-child {
        display: none;
    }
    
    .markdown-content h1 {
        font-family: var(--font-serif);
        font-size: 2.5rem;
        font-weight: 700;
        color: white;
        margin-top: 2rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .markdown-content h2 {
        font-family: var(--font-serif);
        font-size: 1.8rem;
        font-weight: 700;
        color: white;
        margin-top: 3rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .markdown-content h3 {
        font-family: var(--font-sans);
        font-size: 1.4rem;
        font-weight: 600;
        color: #e2e8f0; /* slalt-200 */
        margin-top: 2rem;
        margin-bottom: 1rem;
    }

    .markdown-content p {
        color: #94a3b8; /* slate-400 */
        line-height: 1.8;
        margin-bottom: 1.5rem;
    }

    .markdown-content ul {
        list-style-type: none;
        padding-left: 0;
        margin-bottom: 2rem;
    }

    .markdown-content li {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 0.75rem;
        color: #cbd5e1; /* slate-300 */
    }

    .markdown-content li::before {
        content: "•";
        position: absolute;
        left: 0;
        color: #64ffda; /* accent color */
        font-weight: bold;
    }

    .markdown-content strong {
        color: white;
        font-weight: 600;
    }
    
    .markdown-content code {
        font-family: var(--font-mono);
        color: #64ffda;
        background: rgba(255, 255, 255, 0.05);
        padding: 0.2em 0.4em;
        border-radius: 4px;
        font-size: 0.85em;
        transition: all 0.2s ease;
    }
    
    .markdown-content code:hover {
        background: rgba(255, 255, 255, 0.08);
    }
    
    /* Enhanced code block wrapper */
    .markdown-content pre {
        position: relative;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 8px;
        padding: 1rem;
        overflow-x: auto;
        margin: 1.5rem 0;
        transition: all 0.3s ease;
    }
    
    .markdown-content pre:hover {
        border-color: rgba(100, 255, 218, 0.2);
        background: rgba(255, 255, 255, 0.03);
    }
    
    /* Smooth animations for headings */
    .markdown-content h1, .markdown-content h2, .markdown-content h3 {
        transition: color 0.3s ease;
    }
    
    .markdown-content h1:hover, .markdown-content h2:hover, .markdown-content h3:hover {
        color: #64ffda;
    }
    
    /* Loading animation for sidebar */
    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
    
    .sidebar-loading {
        animation: pulse 2s infinite;
    }
    
    /* Smooth scroll behavior */
    html {
        scroll-behavior: smooth;
    }
</style>
