---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InteractiveBackground from '../components/InteractiveBackground.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
	description?: string;
  image?: string;
  categories?: string[];
}

const { title, description, image, categories } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark" class="scroll-smooth">
	<head>
		<BaseHead title={title || "Tim Varley"} description={description || "Technical Lead & Software Engineer"} />
{import.meta.env.PROD && (
	<>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-VXZ74F9RKM"></script>
		<script>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-VXZ74F9RKM');
		</script>
	</>
)}
    {categories && <meta name="keywords" content={categories.join(', ')}>}
    <!-- KaTeX for math rendering - unified system -->
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/contrib/auto-render.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            renderMathInElement(document.body, {
                delimiters: [
                    {left: "$$", right: "$$", display: true},
                    {left: "$", right: "$", display: false},
                    {left: "\\[", right: "\\]", display: true},
                    {left: "\\(", right: "\\)", display: false}
                ],
                throwOnError: false
            });
        });
    </script>
    <ClientRouter />
	</head>
	<body class="bg-charcoal text-white font-mono antialiased min-h-screen flex flex-col relative selection:bg-steel-blue selection:text-white">
    
    <!-- Background Gradient -->
    <InteractiveBackground />
    
		<Header />
    
		<main class="flex-grow w-full max-w-7xl mx-auto px-6 py-8 md:py-12">
			<slot />
		</main>
    
		<Footer />
    <ScrollReveal />
	</body>
</html>
