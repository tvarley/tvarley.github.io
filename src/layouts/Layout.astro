---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
  image?: string;
  categories?: string[];
}

const { title, description, image, categories } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark" class="scroll-smooth">
	<head>
		<BaseHead title={title || "Tim Varley"} description={description || "Technical Lead & Software Engineer"} />
{import.meta.env.PROD && (
	<>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-VXZ74F9RKM"></script>
		<script>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-VXZ74F9RKM');
		</script>
	</>
)}
    {categories && <meta name="keywords" content={categories.join(', ')}>}
    <!-- MathJax for Euler problems - optimized for mobile -->
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']],
                displayMath: [['$$', '$$'], ['\\[', '\\]']],
                processEscapes: true,
                processEnvironments: true
            },
            options: {
                skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre'],
                // Mobile optimizations
                menuOptions: {
                    autocollapse: true // Collapse menus on mobile
                }
            },
            startup: {
                ready: function() {
                    MathJax.startup.defaultReady();
                    MathJax.startup.promise.then(function() {
                        // Process math after page load
                        if (typeof MathJax !== 'undefined') {
                            MathJax.typesetPromise();
                        }
                    });
                }
            },
            // Performance optimizations
            loader: {
                load: ['[tex]/color'] // Only load needed extensions
            }
        };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" defer></script>
	</head>
	<body class="bg-charcoal text-white font-mono antialiased min-h-screen flex flex-col relative selection:bg-steel-blue selection:text-white">
    
    <!-- Background Gradient -->
    <div class="fixed inset-0 z-[-1] bg-hero-gradient opacity-80 pointer-events-none"></div>
    
		<Header />
    
		<main class="flex-grow w-full max-w-7xl mx-auto px-6 py-8 md:py-12">
			<slot />
		</main>
    
		<Footer />
	</body>
</html>
