---
import { type CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

type Props = CollectionEntry<'euler'>['data'];

const { problemNumber, title, description, difficulty, technologies, implementations } = Astro.props;
---

<Layout title={`Euler ${problemNumber}: ${title}`} description={description}>
	<article class="max-w-4xl mx-auto py-12">
    
    <!-- Header -->
    <header class="mb-16 text-center">
      <div class="inline-flex items-center justify-center gap-3 mb-6">
        <span class="font-mono text-steel-blue bg-steel-blue/10 border border-steel-blue/20 px-3 py-1 rounded-full text-sm font-bold">
          Problem #{problemNumber}
        </span>
        <span class={`text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider ${
          difficulty === 'easy' ? 'text-green-400 bg-green-900/20 border border-green-500/20' :
          difficulty === 'medium' ? 'text-yellow-400 bg-yellow-900/20 border border-yellow-500/20' :
          'text-red-400 bg-red-900/20 border border-red-500/20'
        }`}>{difficulty}</span>
      </div>
      
      <h1 class="text-4xl md:text-6xl font-serif font-black text-white mb-8">{title}</h1>
      
      <div class="prose prose-lg mx-auto bg-matte/50 p-8 rounded-2xl border border-white/5 text-left">
        <p class="text-xl text-silver leading-relaxed font-serif italic m-0">{description}</p>
      </div>

      <div class="mt-8 flex justify-center gap-2">
        {technologies.map(tech => (
          <span class="text-xs font-mono text-white bg-charcoal border border-steel-blue/30 px-3 py-1 rounded">
            {tech}
          </span>
        ))}
      </div>
    </header>

    <!-- Implementations -->
    <div class="space-y-12">
      <h2 class="text-3xl font-serif font-bold text-white mb-8 border-b border-white/10 pb-4">Implementations</h2>
      
      {implementations.map(impl => (
        <div class="bg-matte border border-white/10 rounded-2xl overflow-hidden shadow-glass">
          <div class="bg-charcoal border-b border-white/5 px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-4">
              <span class="font-bold text-white">{impl.language}</span>
              {impl.performance && (
                <span class="text-xs font-mono text-green-400 bg-green-900/20 px-2 py-0.5 rounded border border-green-500/20">
                  {impl.performance}
                </span>
              )}
            </div>
            <a href={impl.githubLink} target="_blank" class="text-xs font-mono text-steel-blue hover:text-white transition-colors flex items-center gap-1">
              View Source <span class="sr-only">on GitHub</span> &rarr;
            </a>
          </div>
          
          {impl.notes && (
            <div class="px-6 py-4 bg-steel-blue/5 border-b border-white/5 text-sm text-silver italic">
              Note: {impl.notes}
            </div>
          )}
          
          <div class="p-0 overflow-x-auto">
            <pre class="!bg-charcoal !m-0 !p-6 !border-0 text-sm font-mono leading-relaxed"><code class={`language-${impl.language.toLowerCase()}`}>{impl.code}</code></pre>
          </div>
        </div>
      ))}
    </div>

    <!-- Back Link -->
    <div class="mt-20 text-center">
      <a href="/euler" class="inline-flex items-center gap-2 text-steel-blue hover:text-white font-mono text-sm transition-colors border border-steel-blue/20 hover:border-steel-blue px-6 py-3 rounded-lg">
        &larr; Back to Solutions
      </a>
    </div>
	</article>
</Layout>
