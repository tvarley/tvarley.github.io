---
import Layout from './Layout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Description from '../components/Description.astro';
import SolutionExporter from '../components/SolutionExporter.astro';

interface Props {
  problemNumber: number;
  title: string;
  description: string;
  difficulty: 'easy' | 'medium' | 'hard';
  technologies: string[];
  implementations: {
    language: string;
    code: string;
    githubLink: string;
    performance?: string;
    notes?: string;
  }[];
  allProblems: CollectionEntry<'euler'>[];
  prevProblem?: CollectionEntry<'euler'>;
  nextProblem?: CollectionEntry<'euler'>;
}

const { problemNumber, title, description, difficulty, technologies, implementations, allProblems, prevProblem, nextProblem } = Astro.props;
---

<Layout title={`Euler ${problemNumber}: ${title}`} description={description}>
    <article class="max-w-4xl mx-auto py-12 px-6">
    
    <!-- Header -->
    <header class="mb-16 text-center relative z-10">
      <!-- Problem Number Badge -->
      <div class="inline-flex items-center justify-center gap-3 mb-6">
        <span class="font-mono text-steel-blue bg-steel-blue/10 border border-steel-blue/20 px-3 py-1 rounded-full text-sm font-bold shadow-glow">
          Problem #{problemNumber}
        </span>
        <span class={`text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider border ${
          difficulty === 'easy' ? 'text-green-400 bg-green-900/20 border-green-500/20' :
          difficulty === 'medium' ? 'text-yellow-400 bg-yellow-900/20 border-yellow-500/20' :
          'text-red-400 bg-red-900/20 border-red-500/20'
        }`}>{difficulty}</span>
      </div>
      
      <!-- Title -->
      <div class="relative z-10 mb-12">
        <h1 class="text-4xl md:text-6xl font-serif font-black text-white leading-normal max-w-4xl mx-auto">
            {title}
        </h1>
      </div>
      
      <!-- Description Box -->
      <div class="relative z-10 mx-auto bg-charcoal/50 backdrop-blur-md p-8 rounded-2xl border border-white/10 text-left shadow-2xl overflow-hidden group">
        <!-- Decoration -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-steel-blue/50 to-transparent opacity-50"></div>
        
        <div class="prose prose-lg prose-invert max-w-none">
            <Description description={description} />
        </div>
      </div>

      <!-- Project Euler Link & Export Controls -->
      <div class="relative z-10 mt-12 mb-8 flex flex-row items-center justify-center gap-6">
        <a 
          href={`https://projecteuler.net/problem=${problemNumber}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-steel-blue/10 border border-steel-blue/20 text-steel-blue hover:bg-steel-blue/20 hover:border-steel-blue/40 transition-all duration-200 font-mono text-sm group"
        >
          <span>View on Project Euler</span>
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4.5a.75.75 0 011.5 0v4.5A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h4.5a.75.75 0 010 1.5h-4.5z" clip-rule="evenodd"></path>
            <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z" clip-rule="evenodd"></path>
          </svg>
        </a>

        <SolutionExporter 
          problemNumber={problemNumber}
          title={title}
          allProblems={allProblems}
        />
      </div>


    </header>

    <!-- Language Tabs -->
    <div class="mb-8" id="language-tabs">
      <div class="flex flex-wrap items-center gap-2 mb-4 overflow-x-auto">
        {implementations.map((impl, index) => (
          <button
            class={"language-tab whitespace-nowrap px-4 py-2 rounded-lg font-mono text-sm transition-all border " + (index === 0 ? 'bg-steel-blue text-white border-steel-blue' : 'bg-white/5 text-white/80 border-white/10 hover:border-steel-blue/50 hover:text-white hover:bg-steel-blue/10')}
            data-language={impl.language.toLowerCase()}
            data-index={index}
          >
            {impl.language}
          </button>
        ))}
        <button
          class="language-tab all-languages whitespace-nowrap px-4 py-2 rounded-lg font-mono text-sm transition-all border bg-white/5 text-white/80 border-white/10 hover:border-steel-blue/50 hover:text-white hover:bg-steel-blue/10"
          data-language="all"
        >
          All Languages
        </button>
      </div>

      <!-- Active Tab Indicator -->
      <div class="h-px bg-steel-blue transition-all duration-300" id="tab-indicator"></div>
    </div>
    <!-- Implementations -->
    <section class="space-y-16" aria-labelledby="implementations-heading">
      <div class="flex items-center gap-4 mb-8">
        <h2 id="implementations-heading" class="text-3xl font-serif font-bold text-white">Implementations</h2>
        <div class="h-px bg-white/10 flex-grow" aria-hidden="true"></div>
      </div>
      
      {implementations.map((impl, index) => (
          <div class={"implementation " + (index === 0 ? '' : 'hidden')} data-language={impl.language.toLowerCase()}>
            <CodeBlock
              code={impl.code}
              language={impl.language.toLowerCase()}
              title={impl.language}
            />
            <div class="mt-4 space-y-3">
              {impl.githubLink && (
                <a href={impl.githubLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-steel-grey hover:text-steel-blue hover:border-steel-blue/50 transition-all duration-200 font-mono text-sm group">
                  <i class="devicon-github-plain"></i>
                  <span>View on GitHub</span>
                  <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4.5a.75.75 0 011.5 0v4.5A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h4.5a.75.75 0 010 1.5h-4.5z" clip-rule="evenodd"></path>
                    <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z" clip-rule="evenodd"></path>
                  </svg>
                </a>
              )}
              {impl.performance && (
                <div class="flex items-center gap-2 text-steel-grey font-mono text-sm">
                  <i class="fas fa-clock text-steel-blue/60"></i>
                  <span>{impl.performance}</span>
                </div>
              )}
              {impl.notes && (
                <div class="text-steel-grey text-sm">
                  {impl.notes}
                </div>
              )}
            </div>
          </div>
      ))}

      <div class="implementation hidden" data-language="all">
        {implementations.map((impl, index) => (
          <div>
            <CodeBlock
              code={impl.code}
              language={impl.language.toLowerCase()}
              title={impl.language}
            />
            <div class="mt-4 space-y-3">
              {impl.githubLink && (
                <a href={impl.githubLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-steel-grey hover:text-steel-blue hover:border-steel-blue/50 transition-all duration-200 font-mono text-sm group">
                  <i class="devicon-github-plain"></i>
                  <span>View on GitHub</span>
                  <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4.5a.75.75 0 011.5 0v4.5A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h4.5a.75.75 0 010 1.5h-4.5z" clip-rule="evenodd"></path>
                    <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z" clip-rule="evenodd"></path>
                  </svg>
                </a>
              )}
              {impl.performance && (
                <div class="flex items-center gap-2 text-steel-grey font-mono text-sm">
                  <i class="fas fa-clock text-steel-blue/60"></i>
                  <span>{impl.performance}</span>
                </div>
              )}
              {impl.notes && (
                <div class="text-steel-grey text-sm">
                  {impl.notes}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Solution Notes / Additional Content -->
    <section id="solution-notes" class="mt-16">
      <div class="relative z-10 mx-auto bg-charcoal/50 backdrop-blur-md p-8 rounded-2xl border border-white/10 text-left shadow-2xl overflow-hidden group">
        <!-- Decoration -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-steel-blue/50 to-transparent opacity-50"></div>
        
        <div class="prose prose-lg prose-invert max-w-none">
          <slot />
        </div>
      </div>
    </section>

    <!-- Navigation -->
    <nav class="mt-24 space-y-8 border-t border-white/10 pt-8">
      <!-- Jump to Problem -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <label class="text-sm font-mono text-steel-grey whitespace-nowrap">Jump to problem:</label>
        <select class="jump-to-problem bg-white/5 border border-white/10 rounded px-3 py-2 text-white text-sm flex-1 sm:flex-none" id="jump-to-problem">
          <option value="">Select a problem...</option>
          {allProblems.map(p => (
            <option value={p.data.problemNumber} selected={p.data.problemNumber === problemNumber}>
              #{p.data.problemNumber.toString().padStart(3, '0')} - {p.data.title}
            </option>
          ))}
        </select>
      </div>

      <!-- Breadcrumb -->
      <div class="text-center">
        <div class="inline-flex items-center gap-2 text-sm font-mono text-steel-grey">
          <a href="/euler" class="hover:text-steel-blue transition-colors">All Problems</a>
          <span>/</span>
          <span class="text-white">Problem {problemNumber}</span>
        </div>
      </div>

      <!-- Previous/Next Navigation -->
      <div class="grid grid-cols-2 gap-4">
        {prevProblem ? (
          <a href={`/euler/${prevProblem.id}/`} class="group flex flex-col items-start p-4 rounded-xl hover:bg-white/5 transition-all text-left">
            <span class="text-xs font-mono text-steel-grey mb-1 group-hover:text-steel-blue transition-colors">← Problem #{prevProblem.data.problemNumber}</span>
            <span class="text-white font-serif font-bold text-lg group-hover:translate-x-1 transition-transform">{prevProblem.data.title}</span>
          </a>
        ) : (
          <div></div>
        )}

        {nextProblem ? (
          <a href={`/euler/${nextProblem.id}/`} class="group flex flex-col items-end p-4 rounded-xl hover:bg-white/5 transition-all text-right">
            <span class="text-xs font-mono text-steel-grey mb-1 group-hover:text-steel-blue transition-colors">Problem #{nextProblem.data.problemNumber} →</span>
            <span class="text-white font-serif font-bold text-lg group-hover:-translate-x-1 transition-transform">{nextProblem.data.title}</span>
          </a>
        ) : (
          <div></div>
        )}
      </div>
    </nav>
    
	</article>

<script>
  // Language tab switching logic - run immediately
  function initLanguageTabs() {
    const languageTabs = document.querySelectorAll('.language-tab');
    const implementations = document.querySelectorAll('.implementation');
    const jumpToProblem = document.getElementById('jump-to-problem');

    function updateTabIndicator() {
      const activeTab = document.querySelector('.language-tab.bg-steel-blue');
      const indicator = document.getElementById('tab-indicator');
      if (activeTab && indicator) {
        const tabRect = activeTab.getBoundingClientRect();
        const containerRect = activeTab.parentElement.getBoundingClientRect();
        indicator.style.width = `${tabRect.width}px`;
        indicator.style.transform = `translateX(${tabRect.left - containerRect.left}px)`;
      }
    }

    // Tab switching logic
    languageTabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const language = this.getAttribute('data-language');
        
        // Update tab styles
        languageTabs.forEach(t => {
          t.classList.remove('bg-steel-blue', 'text-white', 'border-steel-blue');
          t.classList.add('bg-white/5', 'text-white/80', 'border-white/10');
        });
        
        this.classList.remove('bg-white/5', 'text-white/80', 'border-white/10');
        this.classList.add('bg-steel-blue', 'text-white', 'border-steel-blue');
        
        // Show/hide implementations
        implementations.forEach(impl => {
          if (impl.getAttribute('data-language') === language) {
            impl.classList.remove('hidden');
          } else {
            impl.classList.add('hidden');
          }
        });

        // Update tab indicator
        updateTabIndicator();
      });
    });

    // Jump to problem functionality
    if (jumpToProblem) {
      jumpToProblem.addEventListener('change', function() {
        console.log('Jump to problem selected:', this.value);
        if (this.value) {
          window.location.href = `/euler/problem-${this.value.toString().padStart(3, '0')}/`;
        }
      });
    }

    // Initial indicator position
    updateTabIndicator();

    // Update on window resize
    window.addEventListener('resize', updateTabIndicator);
  }

  // Run immediately if DOM is ready, otherwise wait
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLanguageTabs);
  } else {
    initLanguageTabs();
  }
</script>
</Layout>