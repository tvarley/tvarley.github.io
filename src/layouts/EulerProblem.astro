---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'euler'>['data'];

const { problemNumber, title, description, difficulty, date, technologies, implementations, featured, showcase } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`Euler ${problemNumber}: ${title}`} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.header {
				margin-bottom: 2em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.problem-number {
				font-size: 3rem;
				font-weight: bold;
				color: rgb(var(--accent));
				margin-bottom: 0.5rem;
			}
			.title {
				margin: 0 0 1em 0;
				font-size: 2rem;
			}
			.difficulty {
				display: inline-block;
				padding: 0.5rem 1rem;
				border-radius: 8px;
				font-size: 1rem;
				font-weight: bold;
				margin-bottom: 1rem;
			}
			.difficulty.easy { background: #d4edda; color: #155724; }
			.difficulty.medium { background: #fff3cd; color: #856404; }
			.difficulty.hard { background: #f8d7da; color: #721c24; }
			.description {
				font-size: 1.2rem;
				line-height: 1.6;
				margin-bottom: 2rem;
				color: rgb(var(--black));
			}
			.technologies {
				margin-bottom: 2rem;
			}
			.tech-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-top: 0.5rem;
			}
			.tech-tag {
				background: rgb(var(--accent));
				color: white;
				padding: 0.25rem 0.75rem;
				border-radius: 4px;
				font-size: 0.9rem;
				font-weight: bold;
			}
			.implementations {
				margin-bottom: 2rem;
			}
			.implementation {
				border: 1px solid #e5e5e5;
				border-radius: 8px;
				padding: 1rem;
				margin-bottom: 1rem;
			}
			.impl-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
			}
			.impl-language {
				font-weight: bold;
				font-size: 1.1rem;
			}
			.impl-link {
				color: rgb(var(--accent));
				text-decoration: none;
			}
			.impl-link:hover {
				text-decoration: underline;
			}
			.impl-performance {
				font-size: 0.9rem;
				color: rgb(var(--gray));
				margin-bottom: 0.5rem;
			}
			.impl-notes {
				font-size: 0.9rem;
				font-style: italic;
				color: rgb(var(--gray));
				margin-bottom: 0.5rem;
			}
			.impl-code {
				background: #f8f8f8;
				border: 1px solid #e5e5e5;
				border-radius: 4px;
				padding: 1rem;
				font-family: monospace;
				font-size: 0.9rem;
				white-space: pre-wrap;
				overflow-x: auto;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="header">
						<div class="problem-number">#{problemNumber}</div>
						<h1 class="title">{title}</h1>
						<span class={`difficulty ${difficulty}`}>{difficulty.toUpperCase()}</span>
						<p class="description">{description}</p>
						
						<div class="technologies">
							<strong>Languages:</strong>
							<div class="tech-tags">
								{technologies.map(tech => (
									<span class="tech-tag">{tech}</span>
								))}
							</div>
						</div>
					</div>

					<div class="implementations">
						<h2>Implementations</h2>
						{implementations.map(impl => (
							<div class="implementation">
								<div class="impl-header">
									<span class="impl-language">{impl.language}</span>
									<a class="impl-link" href={impl.githubLink} target="_blank">View on GitHub</a>
								</div>
								{impl.performance && (
									<div class="impl-performance">Performance: {impl.performance}</div>
								)}
								{impl.notes && (
									<div class="impl-notes">{impl.notes}</div>
								)}
								<div class="impl-code">{impl.code}</div>
							</div>
						))}
					</div>

					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>