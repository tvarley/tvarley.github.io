---
import { type CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import CodeBlock from '../components/CodeBlock.astro';

interface Props {
  problemNumber: number;
  title: string;
  description: string;
  difficulty: 'easy' | 'medium' | 'hard';
  technologies: string[];
  implementations: {
    language: string;
    code: string;
    githubLink: string;
    performance?: string;
    notes?: string;
  }[];
  prevProblem?: CollectionEntry<'euler'>;
  nextProblem?: CollectionEntry<'euler'>;
}

const { problemNumber, title, description, difficulty, technologies, implementations, prevProblem, nextProblem } = Astro.props;
---

<Layout title={`Euler ${problemNumber}: ${title}`} description={description}>
    <!-- Additional script to ensure math is processed after content loads -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Give MathJax time to load, then process
            setTimeout(function() {
                if (typeof MathJax !== 'undefined' && MathJax.typesetPromise) {
                    MathJax.typesetPromise();
                }
            }, 100);
        });
    </script>

	<article class="max-w-4xl mx-auto py-12 px-6">
    
    <!-- Header -->
    <header class="mb-16 text-center relative">
      <!-- Problem Number Badge -->
      <div class="inline-flex items-center justify-center gap-3 mb-6">
        <span class="font-mono text-steel-blue bg-steel-blue/10 border border-steel-blue/20 px-3 py-1 rounded-full text-sm font-bold shadow-glow">
          Problem #{problemNumber}
        </span>
        <span class={`text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider border ${
          difficulty === 'easy' ? 'text-green-400 bg-green-900/20 border-green-500/20' :
          difficulty === 'medium' ? 'text-yellow-400 bg-yellow-900/20 border-yellow-500/20' :
          'text-red-400 bg-red-900/20 border-red-500/20'
        }`}>{difficulty}</span>
      </div>
      
      <!-- Title -->
      <div class="relative z-10 mb-12">
        <h1 class="text-4xl md:text-6xl font-serif font-black text-white leading-normal max-w-4xl mx-auto">
            {title}
        </h1>
      </div>
      
      <!-- Description Box with Math Support -->
      <div class="relative z-10 mx-auto bg-charcoal/50 backdrop-blur-md p-8 rounded-2xl border border-white/10 text-left shadow-2xl overflow-hidden group">
        <!-- Decoration -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-steel-blue/50 to-transparent opacity-50"></div>
        
        <div class="prose prose-lg prose-invert max-w-none">
            <div class="text-xl text-silver leading-relaxed font-serif italic mb-6">
            {description.split('\n\n').map((paragraph, index) => {
                if (paragraph.trim().startsWith('- ')) {
                    // Handle list items
                    const items = paragraph.split('\n').filter(line => line.trim());
                    return (
                        <ul key={index} class="list-disc list-inside mb-4 space-y-1">
                            {items.map((item, i) => (
                                <li key={i} class="text-silver">{item.replace(/^- /, '')}</li>
                            ))}
                        </ul>
                    );
                } else if (paragraph.trim()) {
                    // Handle regular paragraphs and math blocks
                    return <p key={index} class="text-silver m-0 mb-4 last:mb-0 whitespace-pre-line">{paragraph.trim()}</p>;
                }
                return null;
            })}

            <!-- Markdown Slot for Extended Description / Equations -->
            <div class="not-italic font-sans text-base text-gray-300">
            <slot />
            </div>
        </div>
      </div>

      <!-- Tech Stack -->
      <div class="mt-8 flex flex-wrap justify-center gap-2">
        {technologies.map(tech => (
          <a href={`#${tech.toLowerCase()}-implementation`} class="tech-pill text-xs font-mono text-white/80 bg-white/5 border border-white/10 px-3 py-1 rounded transition-colors hover:border-steel-blue/50 hover:text-white hover:bg-steel-blue/10">
            {tech}
          </a>
        ))}
      </div>
    </header>

    <!-- Implementations -->
    <section class="space-y-16" aria-labelledby="implementations-heading">
      <div class="flex items-center gap-4 mb-8">
        <h2 id="implementations-heading" class="text-3xl font-serif font-bold text-white">Implementations</h2>
        <div class="h-px bg-white/10 flex-grow" aria-hidden="true"></div>
      </div>
      
      {implementations.map((impl, index) => (
          <div class="bg-matte border border-white/10 rounded-2xl overflow-hidden shadow-glass hover:shadow-glow transition-all duration-300 hover:border-steel-blue/30 group-hover:translate-y-[-2px]">
            <!-- Meta Bar -->
            <div class="bg-charcoal/80 backdrop-blur border-b border-white/5 px-6 pt-5 pb-3 flex justify-between items-end">
               <div class="flex items-center gap-3">
                 <!-- Performance Badge -->
                 {impl.performance && (
                    <div class="flex items-center gap-1.5 text-xs font-mono text-green-400">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      {impl.performance}
                    </div>
                  )}
               </div>
               
               <a href={impl.githubLink} target="_blank" class="text-xs font-mono text-steel-blue hover:text-white transition-colors flex items-center gap-1.5 opacity-80 hover:opacity-100">
                  View Raw <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
               </a>
            </div>
            
            {impl.notes && (
              <div class="px-6 py-3 bg-yellow-900/10 border-b border-white/5 text-sm text-yellow-200/80 italic flex gap-2">
                <span class="opacity-50">ℹ</span> {impl.notes}
              </div>
            )}
            
            <div class="p-0 overflow-x-auto">
              <CodeBlock
                code={impl.code}
                language={impl.language.toLowerCase()}
                showLineNumbers={true}
                showCopyButton={true}
                class="rounded-none border-none shadow-none"
                id={`${impl.language.toLowerCase()}-implementation`}
              />
            </div>
          </div>
        </div>
      ))}
    </section>

    <!-- Navigation -->
    <nav class="mt-24 grid grid-cols-2 gap-4 border-t border-white/10 pt-8">
      {prevProblem ? (
        <a href={`/euler/${prevProblem.id}/`} class="group flex flex-col items-start p-4 rounded-xl hover:bg-white/5 transition-all text-left">
          <span class="text-xs font-mono text-steel-grey mb-1 group-hover:text-steel-blue transition-colors">← Problem #{prevProblem.data.problemNumber}</span>
          <span class="text-white font-serif font-bold text-lg group-hover:translate-x-1 transition-transform">{prevProblem.data.title}</span>
        </a>
      ) : (
        <div /> 
      )}

      {nextProblem ? (
        <a href={`/euler/${nextProblem.id}/`} class="group flex flex-col items-end p-4 rounded-xl hover:bg-white/5 transition-all text-right">
          <span class="text-xs font-mono text-steel-grey mb-1 group-hover:text-steel-blue transition-colors">Problem #{nextProblem.data.problemNumber} →</span>
          <span class="text-white font-serif font-bold text-lg group-hover:-translate-x-1 transition-transform">{nextProblem.data.title}</span>
        </a>
      ) : (
        <div />
      )}
    </nav>
    
    <div class="mt-12 text-center">
        <a href="/euler" class="text-sm font-mono text-steel-grey hover:text-white transition-colors border-b border-transparent hover:border-steel-blue pb-0.5">All Solutions</a>
    </div>

	</article>
</Layout>

<style>
  /* Extra styling for MathJax aesthetics if needed */
  mjx-container {
    color: #cbd5e1 !important; /* silver/slate-300 */
    font-size: 1.1em !important;
  }

  .tech-pill {
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .tech-pill:hover {
    transform: translateY(-1px);
  }
</style>
