---
---

<section 
  class="hero-section min-h-[50vh] flex flex-col justify-center items-start mb-12"
  aria-label="Introduction"
>
  <div class="space-y-6 max-w-4xl">
    <div class="flex items-start gap-6 mb-8 md:gap-10 lg:gap-12">
      <!-- Logo -->
      <div class="hero-logo relative flex-shrink-0 w-20 h-20 md:w-28 md:h-28 lg:w-32 lg:h-32 rounded-2xl bg-steel-blue/20 shadow-2xl transition-all duration-500 scale-0 opacity-0">
        <img src="/images/logo3.jpg" alt="Logo" class="absolute inset-0 w-full h-full object-contain rounded-2xl" />
      </div>
      
      <div class="min-w-0 flex-1">
        <!-- Name -->
        <h1 class="hero-name text-6xl md:text-8xl font-black text-white tracking-tight mb-4 translate-y-8 opacity-0">
          Tim <br/> <span class="text-steel-blue inline-block">Varley</span>
        </h1>
        
        <!-- Subtitle -->
        <h2 class="hero-subtitle text-2xl md:text-3xl text-silver font-light max-w-2xl leading-relaxed translate-y-4 opacity-0">
          Technical Lead & Cloud Engineer specializing in AI-driven development and scalable infrastructure.
        </h2>
        
        <!-- CTA Buttons -->
        <div class="hero-actions pt-8 flex flex-wrap gap-4 opacity-0 translate-y-4">
          <a href="/projects" class="btn-primary hover:scale-105 transition-transform duration-300">Featured Projects</a>
          <a href="/euler" class="px-8 py-4 rounded-xl text-white font-medium bg-steel-blue/10 border border-steel-blue/20 hover:bg-steel-blue/20 transition-all duration-300 hover:scale-105">View Euler Solutions</a>
          <a href="/about" class="px-8 py-4 rounded-xl text-white font-medium border border-white/20 hover:bg-white/5 transition-all duration-300 hover:scale-105">About Me</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Fallback for no-js environments */
  @media (scripting: none) {
    .hero-logo, .hero-name, .hero-subtitle, .hero-actions {
      opacity: 1 !important;
      transform: none !important;
      scale: 1 !important;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  // Run immediately to avoid FOUC/delay
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion) {
    gsap.set(".hero-logo, .hero-name, .hero-subtitle, .hero-actions", {
      opacity: 1,
      scale: 1,
      y: 0
    });
  } else {
    const tl = gsap.timeline({
      defaults: { ease: "power3.out" }
    });
    
    // Start animation immediately
    tl.to(".hero-logo", {
      scale: 1,
      opacity: 1,
      duration: 1.2,
      ease: "elastic.out(1, 0.5)"
    })
    .to(".hero-name", {
      y: 0,
      opacity: 1,
      duration: 1,
    }, "-=0.8")
    .to(".hero-subtitle", {
      y: 0,
      opacity: 1,
      duration: 0.8,
    }, "-=0.6")
    .to(".hero-actions", {
      y: 0,
      opacity: 1,
      duration: 0.8,
      ease: "back.out(1.7)"
    }, "-=0.6");
  }
</script>
