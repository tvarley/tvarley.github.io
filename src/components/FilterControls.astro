---
// Component props
interface Props {
  problems: CollectionEntry<'euler'>[];
  initialFilters?: {
    difficulty?: string[];
    search?: string;
    sort?: string;
  };
}

// Extract unique values for filters
const { problems, initialFilters } = Astro.props;

// Language to icon mapping
const languageIcons = {
  python: 'devicon-python-plain',
  rust: 'devicon-rust-plain',
  javascript: 'devicon-javascript-plain',
  java: 'devicon-java-plain',
  'c++': 'devicon-cplusplus-plain',
  cpp: 'devicon-cplusplus-plain',
  go: 'devicon-go-plain',
  ruby: 'devicon-ruby-plain',
  c: 'devicon-c-plain',
  php: 'devicon-php-plain',
  swift: 'devicon-swift-plain',
  kotlin: 'devicon-kotlin-plain',
  typescript: 'devicon-typescript-plain',
  scala: 'devicon-scala-plain',
  haskell: 'devicon-haskell-plain',
  clojure: 'devicon-clojure-plain',
  erlang: 'devicon-erlang-plain',
  elixir: 'devicon-elixir-plain',
  r: 'devicon-r-plain',
  matlab: 'devicon-matlab-plain',
  julia: 'devicon-julia-plain',
  perl: 'devicon-perl-plain',
  lua: 'devicon-lua-plain',
  shell: 'devicon-bash-plain',
  bash: 'devicon-bash-plain',
  // default
  default: 'devicon-code-plain'
};

// Get unique difficulties (should be easy/medium/hard based on schema)
const difficulties = ['easy', 'medium', 'hard'];
---

<div id="filter-controls" class="filter-controls glass-card mb-8 p-6 relative z-20"
     data-problems={JSON.stringify(problems)}
     data-initial-filters={JSON.stringify(initialFilters)}>
  <!-- Mobile Filter Toggle -->
  <div class="mobile-filters-toggle mb-4 md:hidden">
    <button
      type="button"
      class="mobile-toggle-btn w-full px-4 py-3 rounded-lg text-primary hover:text-accent transition-colors flex items-center justify-between border"
      aria-expanded="false"
      aria-label="Toggle filters visibility"
    >
      <span class="font-medium">Filters</span>
      <svg class="w-5 h-5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
  </div>

  <div class="mobile-filters-content">
  <div class="flex flex-col lg:flex-row lg:items-center gap-6">
    <!-- Sorting Controls -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="sort-group">
        <label class="block text-sm font-medium mb-2">Sort by</label>
        <select class="sort-select bg-white/5 border border-white/10 rounded px-3 py-2 text-white text-sm focus:outline-none focus:ring-2 transition-colors" aria-label="Sort problems by">
          <option value="number-asc">Problem # ↑</option>
          <option value="number-desc">Problem # ↓</option>
          <option value="difficulty">Difficulty</option>
          <option value="title">Title A-Z</option>
        </select>
      </div>

      <!-- Search Filter -->
      <div class="filter-group flex-1">
        <label class="block text-sm font-medium mb-2">Search</label>
        <div class="relative">
          <input
            type="text"
            placeholder="Search"
            class="search-input w-full px-3 py-2 rounded-lg focus:outline-none focus:ring-2 transition-colors"
            data-filter="search"
            aria-label="Search problems by title or description"
          />
          <div class="absolute top-1/2 right-3 transform -translate-y-1/2 pointer-events-none">
            <svg class="h-4 w-4 text-silver/60" fill="none" viewBox="0 0 20 20">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Difficulty Filter -->
  <div class="filter-group mt-6">
    <label class="block text-sm font-medium mb-2">Difficulty</label>
    <div class="flex flex-wrap gap-2">
      {difficulties.map(difficulty => (
        <label class="filter-checkbox">
          <input
            type="checkbox"
            value={difficulty}
            class="sr-only"
            data-filter="difficulty"
          />
          <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-medium cursor-pointer transition-all ${
            difficulty === 'easy' ? 'text-green-400 bg-green-900/20 hover:bg-green-900/30' :
            difficulty === 'medium' ? 'text-yellow-400 bg-yellow-900/20 hover:bg-yellow-900/30' :
            'text-red-400 bg-red-900/20 hover:bg-red-900/30'
          }`} aria-label={`Filter by ${difficulty} difficulty problems`}>
            {difficulty.charAt(0).toUpperCase() + difficulty.slice(1)}
          </span>
        </label>
      ))}
    </div>
  </div>

    <!-- Results & Actions -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 lg:w-64 mt-6">
      <div class="results-count text-sm">
        <span class="font-medium" id="results-count" aria-live="polite" aria-atomic="true">{problems.length}</span> problems
      </div>

      <button
        type="button"
        class="clear-filters-btn px-4 py-2 text-sm font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        disabled
        aria-label="Clear all active filters"
      >
        Clear filters
      </button>
    </div>
  </div>

  <!-- Active Filters Display -->
  <div class="active-filters mt-4 hidden">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-xs font-medium uppercase tracking-wider">Active filters:</span>
      <div class="active-filters-list flex flex-wrap gap-2"></div>
    </div>
  </div>
</div>

<style>
  .filter-controls {
    background-color: var(--glass-bg);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
  }

  .mobile-toggle-btn {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: var(--border);
    color: var(--text-primary);
  }

  .mobile-toggle-btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .search-input {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    color: var(--text-primary);
    line-height: 1.5;
  }

  .search-input::placeholder {
    color: var(--text-secondary);
    opacity: 0.6;
  }

  .sort-select {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    color: var(--text-primary);
  }

  .sort-select:focus {
    --tw-ring-color: rgba(var(--accent-rgb, 70, 130, 180), 0.5);
    --tw-border-color: rgba(var(--accent-rgb, 70, 130, 180), 0.5);
  }

  .clear-filters-btn {
    color: var(--text-secondary);
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
  }

  .clear-filters-btn:hover:not(:disabled) {
    color: var(--text-primary);
    background-color: rgba(255, 255, 255, 0.1);
  }

  .results-count {
    color: var(--text-secondary);
  }

  .results-count span {
    color: var(--text-primary);
  }

  .active-filters span:first-child {
    color: var(--text-secondary);
  }

  .filter-group label {
    color: var(--text-secondary);
  }

  .filter-checkbox input:checked + span {
    --tw-ring-color: rgba(var(--accent-rgb, 70, 130, 180), 0.5);
  }

  .active-filter-badge {
    background-color: rgba(var(--accent-rgb, 70, 130, 180), 0.2);
    color: var(--accent);
    border: 1px solid rgba(var(--accent-rgb, 70, 130, 180), 0.3);
  }

  /* Mobile responsive styles */
  @media (max-width: 768px) {
    .filter-controls .grid-cols-2 {
      @apply grid-cols-1 gap-4;
    }

    .filter-controls .flex-row {
      @apply flex-col items-stretch gap-4;
    }

    .filter-controls .lg\\:w-64 {
      @apply w-full;
    }

    /* Collapsible filters for mobile */
    .mobile-filters-toggle {
      @apply block;
    }

    .mobile-filters-content {
      @apply hidden;
    }

    .mobile-filters-content.show {
      @apply block;
    }
  }
</style>

<script>
  // Client-side filtering logic will be implemented here
  class FilterControls {
    constructor(element, problems, initialFilters = {}) {
      this.element = element;
      this.allProblems = problems;
      this.filteredProblems = [...problems];
      this.filters = {
        difficulty: initialFilters.difficulty || [],
        search: initialFilters.search || '',
        sort: initialFilters.sort || 'number-asc'
      };

      this.init();
    }

    init() {
      this.bindEvents();
      this.setInitialFilterState();
      this.applyFilters();
    }

    setInitialFilterState() {
      // Set initial checkbox states based on URL filters
      this.filters.difficulty.forEach(difficulty => {
        const checkbox = this.element.querySelector(`[data-filter="difficulty"][value="${difficulty}"]`);
        if (checkbox) checkbox.checked = true;
      });

      const searchInput = this.element.querySelector('[data-filter="search"]');
      if (searchInput) searchInput.value = this.filters.search;
    }

    bindEvents() {
      // Mobile toggle button
      const mobileToggle = this.element.querySelector('.mobile-toggle-btn');
      const mobileContent = this.element.querySelector('.mobile-filters-content');

      if (mobileToggle && mobileContent) {
        mobileToggle.addEventListener('click', () => {
          const isExpanded = mobileToggle.getAttribute('aria-expanded') === 'true';
          mobileToggle.setAttribute('aria-expanded', !isExpanded);
          mobileContent.classList.toggle('show');

          // Rotate arrow icon
          const arrow = mobileToggle.querySelector('svg');
          if (arrow) {
            arrow.style.transform = isExpanded ? 'rotate(0deg)' : 'rotate(180deg)';
          }
        });
      }

      // Sort select
      const sortSelect = this.element.querySelector('.sort-select');
      if (sortSelect) {
        sortSelect.value = this.filters.sort;
        sortSelect.addEventListener('change', (e) => {
          this.updateSortFilter(e.target.value);
        });
      }

      // Difficulty checkboxes
      this.element.querySelectorAll('[data-filter="difficulty"]').forEach(checkbox => {
        checkbox.addEventListener('change', (e) => {
          this.updateDifficultyFilter(e.target);
        });
      });

      // Search input with debounce
      const searchInput = this.element.querySelector('[data-filter="search"]');
      let debounceTimer;
      searchInput.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          this.updateSearchFilter(e.target.value);
        }, 300);
      });

      // Clear filters button
      this.element.querySelector('.clear-filters-btn').addEventListener('click', () => {
        this.clearAllFilters();
      });
    }

    updateDifficultyFilter(checkbox) {
      if (checkbox.checked) {
        this.filters.difficulty.push(checkbox.value);
      } else {
        this.filters.difficulty = this.filters.difficulty.filter(d => d !== checkbox.value);
      }
      this.applyFilters();
    }

    updateSearchFilter(value) {
      this.filters.search = value.trim();
      this.applyFilters();
    }

    updateSortFilter(value) {
      this.filters.sort = value;
      this.applyFilters();
    }

    applyFilters() {
      let filtered = this.allProblems.filter(problem => {
        // Difficulty filter
        if (this.filters.difficulty.length > 0 && !this.filters.difficulty.includes(problem.data.difficulty)) {
          return false;
        }

        // Search filter
        if (this.filters.search) {
          const searchTerm = this.filters.search.toLowerCase();
          const searchableText = `${problem.data.title} ${problem.data.description}`.toLowerCase();
          if (!searchableText.includes(searchTerm)) {
            return false;
          }
        }

        return true;
      });

      // Apply sorting
      filtered = this.sortProblems(filtered);

      this.filteredProblems = filtered;
      this.updateURL();
      this.render();
      this.dispatchFilterEvent();
    }

    sortProblems(problems) {
      return [...problems].sort((a, b) => {
        switch (this.filters.sort) {
          case 'number-asc':
            return a.data.problemNumber - b.data.problemNumber;
          case 'number-desc':
            return b.data.problemNumber - a.data.problemNumber;
          case 'difficulty':
            const difficultyOrder = { easy: 1, medium: 2, hard: 3 };
            return difficultyOrder[a.data.difficulty] - difficultyOrder[b.data.difficulty];
          case 'title':
            return a.data.title.localeCompare(b.data.title);
          default:
            return 0;
        }
      });
    }

    updateURL() {
      const params = new URLSearchParams();

      if (this.filters.difficulty.length > 0) {
        params.set('difficulty', this.filters.difficulty.join(','));
      }

      if (this.filters.search) {
        params.set('search', this.filters.search);
      }

      if (this.filters.sort !== 'number-asc') {
        params.set('sort', this.filters.sort);
      }

      const newURL = params.toString() ? `${window.location.pathname}?${params.toString()}` : window.location.pathname;
      window.history.replaceState({}, '', newURL);
    }

    render() {
      // Update results count
      const countElement = this.element.querySelector('#results-count');
      if (countElement) {
        countElement.textContent = this.filteredProblems.length;
      }

      // Update clear filters button
      const clearBtn = this.element.querySelector('.clear-filters-btn');
      const hasActiveFilters = this.filters.difficulty.length > 0 ||
                              this.filters.search.length > 0;
      if (clearBtn) {
        clearBtn.disabled = !hasActiveFilters;
      }

      // Update active filters display
      this.renderActiveFilters();
    }

    renderActiveFilters() {
      const activeFiltersContainer = this.element.querySelector('.active-filters');
      const activeFiltersList = this.element.querySelector('.active-filters-list');

      if (!activeFiltersContainer || !activeFiltersList) return;

      // Clear existing badges
      activeFiltersList.innerHTML = '';

      // Add difficulty badges
      this.filters.difficulty.forEach(difficulty => {
        const badge = this.createFilterBadge(`Difficulty: ${difficulty}`, () => {
          const checkbox = this.element.querySelector(`[data-filter="difficulty"][value="${difficulty}"]`);
          if (checkbox) {
            checkbox.checked = false;
            this.updateDifficultyFilter(checkbox);
          }
        });
        activeFiltersList.appendChild(badge);
      });

      // Add search badge
      if (this.filters.search) {
        const badge = this.createFilterBadge(`Search: "${this.filters.search}"`, () => {
          const searchInput = this.element.querySelector('[data-filter="search"]');
          if (searchInput) {
            searchInput.value = '';
            this.updateSearchFilter('');
          }
        });
        activeFiltersList.appendChild(badge);
      }

      // Show/hide active filters section
      const hasActiveFilters = this.filters.difficulty.length > 0 ||
                              this.filters.search.length > 0 ||
                              this.filters.sort !== 'number-asc';
      activeFiltersContainer.classList.toggle('hidden', !hasActiveFilters);
    }

    createFilterBadge(text, onRemove) {
      const badge = document.createElement('span');
      badge.className = 'active-filter-badge';
      badge.setAttribute('aria-label', `Active filter: ${text}`);

      const textSpan = document.createElement('span');
      textSpan.textContent = text;
      badge.appendChild(textSpan);

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'ml-1 hover:text-white/80';
      removeBtn.innerHTML = '×';
      removeBtn.setAttribute('aria-label', `Remove ${text} filter`);
      removeBtn.addEventListener('click', onRemove);
      badge.appendChild(removeBtn);

      return badge;
    }

    clearAllFilters() {
      // Clear difficulty checkboxes
      this.element.querySelectorAll('[data-filter="difficulty"]').forEach(checkbox => {
        checkbox.checked = false;
      });

      // Clear search input
      const searchInput = this.element.querySelector('[data-filter="search"]');
      if (searchInput) searchInput.value = '';

      // Clear sort select
      const sortSelect = this.element.querySelector('.sort-select');
      if (sortSelect) sortSelect.value = 'number-asc';

      this.filters = {
        difficulty: [],
        search: '',
        sort: 'number-asc'
      };

      this.applyFilters();
    }

    dispatchFilterEvent() {
      const event = new CustomEvent('problemsFiltered', {
        detail: { filteredProblems: this.filteredProblems }
      });
      this.element.dispatchEvent(event);
    }

    getFilteredProblems() {
      return this.filteredProblems;
    }
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    const filterElement = document.getElementById('filter-controls');
    if (filterElement) {
      // Read data from element attributes
      const problems = JSON.parse(filterElement.dataset.problems || '[]');
      const initialFilters = JSON.parse(filterElement.dataset.initialFilters || '{}');

      const filterControls = new FilterControls(filterElement, problems, initialFilters);
      window.filterControls = filterControls;

      // Listen for filter events to update the grid
      filterElement.addEventListener('problemsFiltered', (e) => {
        updateProblemsGrid(e.detail.filteredProblems);
      });
    }
  });

  function updateProblemsGrid(filteredProblems) {
    const grid = document.getElementById('problems-grid');
    const emptyState = document.getElementById('empty-state');

    const languageIcons = {
      python: 'devicon-python-plain',
      rust: 'devicon-rust-plain',
      javascript: 'devicon-javascript-plain',
      java: 'devicon-java-plain',
      'c++': 'devicon-cplusplus-plain',
      cpp: 'devicon-cplusplus-plain',
      go: 'devicon-go-plain',
      ruby: 'devicon-ruby-plain',
      c: 'devicon-c-plain',
      php: 'devicon-php-plain',
      swift: 'devicon-swift-plain',
      kotlin: 'devicon-kotlin-plain',
      typescript: 'devicon-typescript-plain',
      scala: 'devicon-scala-plain',
      haskell: 'devicon-haskell-plain',
      clojure: 'devicon-clojure-plain',
      erlang: 'devicon-erlang-plain',
      elixir: 'devicon-elixir-plain',
      r: 'devicon-r-plain',
      matlab: 'devicon-matlab-plain',
      julia: 'devicon-julia-plain',
      perl: 'devicon-perl-plain',
      lua: 'devicon-lua-plain',
      shell: 'devicon-bash-plain',
      bash: 'devicon-bash-plain',
      default: 'devicon-code-plain'
    };

    if (!grid) return;

    // Clear existing cards
    grid.innerHTML = '';

    if (filteredProblems.length === 0) {
      // Show empty state
      if (emptyState) emptyState.classList.remove('hidden');
      return;
    } else {
      // Hide empty state
      if (emptyState) emptyState.classList.add('hidden');
    }

    // Render filtered cards
    filteredProblems.forEach(problem => {
      const card = document.createElement('a');
      card.href = `/euler/${problem.id}/`;
      card.className = 'glass-card group flex flex-col h-full no-underline p-6';
      card.setAttribute('aria-label', `View solution for Problem ${problem.data.problemNumber}: ${problem.data.title}`);

      card.innerHTML = `
        <div class="flex justify-between items-start mb-4">
          <span class="font-mono text-xl font-bold text-steel-blue/80 group-hover:text-steel-blue transition-colors">#${problem.data.problemNumber.toString().padStart(3, '0')}</span>
          <span class="text-[0.6rem] font-bold px-2 py-1 rounded uppercase tracking-widest ${
            problem.data.difficulty === 'easy' ? 'text-green-400 bg-green-900/20' :
            problem.data.difficulty === 'medium' ? 'text-yellow-400 bg-yellow-900/20' :
            'text-red-400 bg-red-900/20'
          }">${problem.data.difficulty}</span>
        </div>
        <h4 class="text-lg font-serif font-bold text-white mb-2 leading-tight">${problem.data.title}</h4>
        <p class="text-sm text-silver/80 mb-4 line-clamp-2">${
          problem.data.description.length > 100 
            ? problem.data.description.substring(0, 100) + '...'
            : problem.data.description
        }</p>
        <div class="flex items-center justify-end mt-auto pt-4">
          
          <div class="flex flex-wrap gap-1">
            ${problem.data.technologies.slice(0, problem.data.technologies.length <= 10 ? problem.data.technologies.length : 3).map(tech => 
              `<span class="text-[0.6rem] font-mono text-silver/60 bg-white/5 px-1.5 py-0.5 rounded flex items-center gap-1" title="${tech}"><i class="${languageIcons[tech.toLowerCase()] || languageIcons.default}"></i></span>`
            ).join('')}
            ${problem.data.technologies.length > 10 ? 
              `<span class="text-[0.6rem] font-mono text-silver/60 bg-white/5 px-1.5 py-0.5 rounded">+${problem.data.technologies.length - 3}</span>` 
              : ''}
          </div>
        </div>
      `;

      grid.appendChild(card);
    });
  }
</script>