---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  currentPost: CollectionEntry<'writings'>;
}

const { currentPost } = Astro.props;
const { series, seriesTitle } = currentPost.data;

if (!series) {
  return;
}

// Fetch all posts in this series
const allPosts = await getCollection('writings');
const seriesPosts = allPosts
  .filter((post) => post.data.series === series && !post.data.draft)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const currentIndex = seriesPosts.findIndex((p) => p.id === currentPost.id);
const totalParts = seriesPosts.length;
const displayTitle = seriesTitle || seriesPosts[0]?.data.seriesTitle || series;
---

<nav class="mb-8 p-4 bg-white/5 border border-white/10 rounded-xl" aria-label="Series navigation">
  <div class="flex flex-col gap-3">
    <div class="flex items-center justify-between text-sm">
      <span class="font-mono text-steel-blue uppercase tracking-widest text-xs font-bold">
        Series: {displayTitle}
      </span>
      <span class="text-silver/60 font-mono text-xs">
        Part {currentIndex + 1} of {totalParts}
      </span>
    </div>
    
    <div class="w-full bg-white/10 h-1 rounded-full overflow-hidden">
      <div 
        class="bg-steel-blue h-full rounded-full transition-all duration-500"
        style={`width: ${((currentIndex + 1) / totalParts) * 100}%`}
      ></div>
    </div>

    <details class="group cursor-pointer">
      <summary class="list-none flex items-center gap-2 text-sm text-silver hover:text-white transition-colors select-none">
        <span class="font-medium">Table of Contents</span>
        <svg class="w-4 h-4 text-steel-grey group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      
      <div class="mt-3 space-y-1 pl-1">
        {seriesPosts.map((post, index) => {
          const isCurrent = post.id === currentPost.id;
          return (
            <a 
              href={`/writings/${post.id}/`} 
              class={`block py-1.5 px-3 rounded text-sm transition-colors ${
                isCurrent 
                  ? 'bg-steel-blue/10 text-steel-blue font-medium border-l-2 border-steel-blue' 
                  : 'text-silver/80 hover:text-white hover:bg-white/5 border-l-2 border-transparent'
              }`}
            >
              <span class="font-mono text-xs opacity-60 mr-2">{index + 1}.</span>
              {post.data.title}
            </a>
          );
        })}
      </div>
    </details>
  </div>
</nav>
