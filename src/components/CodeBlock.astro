---
import { Code } from 'astro-expressive-code/components';

interface Props {
  code: string;
  language: string;
  id?: string;
  title?: string;
  showLineNumbers?: boolean;
  showCopyButton?: boolean;
  class?: string;
}

const { code, language, id, title, showLineNumbers = true, showCopyButton = true, class: className } = Astro.props;
---

<div class="code-block-container" id={id} class={className}>
  <Code
    code={code}
    lang={language}
    title={title}
    showLineNumbers={showLineNumbers}
    showCopyButton={showCopyButton}
  />
</div>

<style>
  .code-block-container {
    @apply my-6;
  }

  /* Custom styling for the Expressive Code component to match our site's design */
  :global(.expressive-code .frame) {
    @apply rounded-2xl overflow-hidden shadow-glass;
    background: linear-gradient(135deg, rgba(26, 26, 26, 0.95), rgba(26, 26, 26, 0.9));
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  :global(.expressive-code .frame-header) {
    @apply bg-charcoal/80 backdrop-blur border-b border-white/5 px-4 py-3;
  }

  :global(.expressive-code .frame-title-bar) {
    @apply bg-charcoal/80 backdrop-blur border-b border-white/5 px-4 py-3;
  }

  :global(.expressive-code .frame-content) {
    @apply bg-charcoal border-none;
  }

  :global(.expressive-code .copy-button) {
    @apply bg-steel-blue/10 hover:bg-steel-blue/20 border border-steel-blue/30 hover:border-steel-blue/50 transition-colors;
  }

  :global(.expressive-code .copy-button:hover) {
    @apply bg-steel-blue/20;
  }

  /* Enhanced mobile code block styles */
  @media (max-width: 768px) {
    .code-block-container {
      margin: 0 -0.5rem; /* Less aggressive edge extension */
      position: relative;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch; /* Smooth scrolling on iOS */
    }
    
    /* Add scroll indicator */
    .code-block-container.has-horizontal-scroll::after {
      content: '';
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      width: 20px;
      background: linear-gradient(to left, var(--bg-primary), transparent);
      pointer-events: none;
      z-index: 1;
    }
    
    :global(.expressive-code .frame) {
      @apply rounded-lg;
      margin: 0; /* Remove negative margins that cause overflow */
      min-width: calc(100vw - 2rem); /* Ensure minimum readable width */
    }
    :global(.expressive-code .frame-header) {
      @apply px-3 py-2.5;
    }
    :global(.expressive-code .frame-title-bar) {
      @apply px-3 py-2.5;
    }
    :global(.expressive-code .frame pre) {
      font-size: 0.875rem; /* Slightly smaller font */
      line-height: 1.4;
    }
    :global(.expressive-code .copy-button) {
      @apply p-3; /* Larger touch target */
      min-width: 48px;
      min-height: 48px;
    }
  }
</style>

<script>
function addScrollIndicators() {
  const codeBlocks = document.querySelectorAll('.code-block-container');
  
  codeBlocks.forEach(block => {
    const pre = block.querySelector('pre');
    if (pre && pre.scrollWidth > pre.clientWidth) {
      block.classList.add('has-horizontal-scroll');
    }
  });
}

document.addEventListener('DOMContentLoaded', addScrollIndicators);
</script>