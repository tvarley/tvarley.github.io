---
import { SITE_TITLE } from '../consts';
---

<header class="sticky top-0 z-50 w-full transition-all duration-300 border-b border-steel-blue/10 bg-charcoal/80 backdrop-blur-md">
	<div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
		
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-3 no-underline">
      <img src="/images/logo2.jpg" alt="Tim Varley Logo" class="w-10 h-10 rounded-lg border border-steel-blue/30 shadow-subtle-glow group-hover:shadow-glass group-hover:border-steel-blue/60 transition-all duration-500 object-contain">
      <div class="flex flex-col">
        <span class="font-serif font-bold text-xl leading-none tracking-tight text-white group-hover:text-steel-blue transition-colors">Tim Varley</span>
        <span class="font-mono text-[0.65rem] uppercase tracking-widest text-steel-grey mt-0.5">Technical Lead</span>
      </div>
    </a>

    <!-- Desktop Nav -->
		<nav class="hidden md:flex items-center gap-8">
			<a href="/" class="nav-link" data-nav-link>Home</a>
			<a href="/projects" class="nav-link" data-nav-link>Projects</a>
			<a href="/euler" class="nav-link" data-nav-link>Euler</a>
			<a href="/about" class="nav-link" data-nav-link>About</a>
      
      <div class="w-px h-6 bg-steel-blue/20 mx-2"></div>
      
      <div class="flex gap-4">
        <a href="https://github.com/tvarley" target="_blank" class="text-steel-grey hover:text-white transition-colors" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        </a>
        <a href="https://linkedin.com/in/timothyvarley" target="_blank" class="text-steel-grey hover:text-white transition-colors" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>
		</nav>

    <!-- Mobile Menu Button (Placeholder for now, keeping it simple as per plan to avoid excessive JS) -->
    <a href="/euler" class="md:hidden text-sm font-mono text-steel-blue border border-steel-blue/30 rounded px-3 py-1">Menu</a>
	</div>
</header>

<script>
  // Simple active state script
  const navLinks = document.querySelectorAll('[data-nav-link]');
  const currentPath = window.location.pathname;
  
  navLinks.forEach(link => {
    if (link instanceof HTMLAnchorElement && (link.getAttribute('href') === currentPath || (link.getAttribute('href') !== '/' && currentPath.startsWith(link.getAttribute('href') || '')))) {
      link.classList.add('active');
    }
  });
</script>
