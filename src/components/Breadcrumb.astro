---
interface Props {
  className?: string;
  items?: { label: string; href?: string }[];
}

const { className = '', items = [] } = Astro.props;
---

<nav aria-label="Breadcrumb" class={`flex items-center space-x-2 text-sm font-mono text-silver/60 mb-6 ${className}`}>
  <a href="/" class="hover:text-white transition-colors">Home</a>
  <span class="opacity-40">/</span>
  <a href="/writings" class="hover:text-white transition-colors">Essays</a>
  
  {items.map((item, index) => (
    <>
      <span class="opacity-40">/</span>
      {item.href ? (
        <a href={item.href} class="hover:text-white transition-colors truncate max-w-[150px] md:max-w-none">
          {item.label}
        </a>
      ) : (
        <span class="text-white font-medium truncate max-w-[150px] md:max-w-none" aria-current="page">
          {item.label}
        </span>
      )}
    </>
  ))}
</nav>
