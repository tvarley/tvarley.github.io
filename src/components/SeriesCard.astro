---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	seriesTitle: string;
	posts: CollectionEntry<'writings'>[];
	description?: string;
    heroImage?: string;
    id?: string; // ID of the overview post if it exists
}

const { seriesTitle, posts, description, heroImage, id } = Astro.props;

// Sort posts by order
const sortedPosts = posts.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
const lastUpdated = sortedPosts.length > 0 ? sortedPosts[sortedPosts.length - 1].data.date : new Date();

// Link to the overview page if ID is provided, otherwise first post
const mainLinkUrl = id ? `/writings/${id}/` : (sortedPosts.length > 0 ? `/writings/${sortedPosts[0].id}/` : '#');
---

<div class="group relative flex flex-col h-full bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-steel-blue/30 transition-all duration-300 hover:shadow-glass hover:-translate-y-1">
	
	{/* Image Area - Linked */}
	<a href={mainLinkUrl} class="block h-48 w-full bg-charcoal-light border-b border-white/5 relative overflow-hidden group-hover:opacity-90 transition-opacity">
        {heroImage ? (
            <img src={heroImage} alt={seriesTitle} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
        ) : (
            <div class="absolute inset-0 flex items-center justify-center text-white/5">
                <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
        )}
		
        {/* Gradient Overlay (stronger if image is present) */}
		<div class={`absolute inset-0 bg-gradient-to-t ${heroImage ? 'from-charcoal via-charcoal/50 to-transparent' : 'from-charcoal/80 to-transparent'}`}></div>
		
		{/* Series Badge */}
		<div class="absolute top-4 left-4">
			<span class="px-2 py-1 text-xs font-mono font-bold uppercase tracking-widest text-white bg-steel-blue/90 backdrop-blur-md rounded shadow-sm border border-white/10">
				Series
			</span>
		</div>

		{/* Part Count Badge */}
		<div class="absolute bottom-4 right-4">
			<span class="px-2 py-1 text-xs font-mono text-silver bg-black/60 backdrop-blur-md rounded border border-white/10 shadow-sm">
				{sortedPosts.length} Parts
			</span>
		</div>
	</a>

	<div class="flex flex-col flex-1 p-6">
		<div class="mb-4">
			<a href={mainLinkUrl} class="block">
				<h3 class="text-2xl font-serif font-bold text-white mb-2 leading-tight group-hover:text-steel-blue transition-colors">
					{seriesTitle}
				</h3>
			</a>
			{description && (
				<p class="text-sm text-steel-grey line-clamp-2 leading-relaxed">
					{description}
				</p>
			)}
		</div>

		{/* Nested Chapter List */}
		<div class="flex-1 space-y-2 mb-6">
			{sortedPosts.slice(0, 3).map((post, index) => (
				<a href={`/writings/${post.id}/`} class="block group/item hover:bg-white/5 rounded px-2 -mx-2 py-1 transition-colors">
					<div class="flex items-baseline gap-3 text-sm">
						<span class="font-mono text-steel-blue/70 text-xs">{(index + 1).toString().padStart(2, '0')}</span>
						<span class="text-silver group-hover/item:text-white transition-colors line-clamp-1">{post.data.title}</span>
					</div>
				</a>
			))}
			{sortedPosts.length > 3 && (
				<div class="text-xs text-steel-grey/50 italic pl-2">
					+ {sortedPosts.length - 3} more parts...
				</div>
			)}
		</div>

		<div class="mt-auto pt-4 border-t border-white/5 flex items-center justify-between">
			<span class="text-xs font-mono text-steel-grey">
				Updated <FormattedDate date={lastUpdated} />
			</span>
			<a href={mainLinkUrl} class="text-steel-blue text-sm font-medium flex items-center gap-1 group-hover:translate-x-1 transition-transform">
				Read Series
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
			</a>
		</div>
	</div>
</div>
