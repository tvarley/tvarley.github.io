---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog - Tim Varley" description="Thoughts on software engineering, leadership, and technology.">
	<section class="py-12">
    <div class="max-w-3xl mb-16">
      <h1 class="text-5xl md:text-6xl font-black text-white mb-6">Blog <span class="text-steel-blue">Posts</span></h1>
      <p class="text-xl text-steel-grey leading-relaxed">
        Thoughts on software engineering, technical leadership, and the craft of building digital products.
      </p>
    </div>

		<div class="space-y-12 max-w-4xl">
			{
				posts.map((post) => (
					<article class="group relative flex flex-col items-start">
            <div class="font-mono text-sm text-steel-blue mb-2 uppercase tracking-widest pl-1">
              <FormattedDate date={post.data.date} />
            </div>
						<h2 class="text-2xl font-serif font-bold text-white mb-3 group-hover:text-steel-blue transition-colors">
              <a href={`/blog/${post.id}/`} class="no-underline text-white group-hover:text-steel-blue">
                {post.data.title}
              </a>
						</h2>
            {post.data.summary && (
              <p class="text-steel-grey leading-relaxed mb-4 max-w-2xl">
                {post.data.summary}
              </p>
            )}
            <a href={`/blog/${post.id}/`} class="font-mono text-xs text-silver hover:text-white border-b border-white/20 hover:border-white transition-colors pb-0.5 mt-auto">Read Article &rarr;</a>
					</article>
				))
			}
		</div>
	</section>
</Layout>
