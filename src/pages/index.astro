---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = await getCollection('euler');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="posts">
				{sortedPosts.map((post) => (
					<div class="post">
						<a href={`/euler/${post.id}`} class="post-link">
							<p class="post-meta">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
							<h3 class="h2 post-title">{post.data.problemNumber}: {post.data.title}</h3>
							<p class="post-summary">{post.data.description.slice(0, 150)}...</p>
						</a>
					</div>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
